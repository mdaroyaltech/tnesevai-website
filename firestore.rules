// firestore.rules
// Copy-paste this in Firebase Console → Firestore → Rules tab

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Services: anyone can read, only logged-in admin can write
    match /services/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Exams: anyone can read, only logged-in admin can write
    match /exams/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Notifications: anyone can read, only logged-in admin can write
    match /notifications/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Settings (contact info etc): anyone can read, only admin can write
    match /settings/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
